generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Project {
  id                        String    @id @default(cuid())
  name                      String
  status                    String    @default("active")
  orgId                     String    @map("org_id")
  structureType             String    @map("structure_type")
  structureLocked           Boolean   @default(false) @map("structure_locked")
  startDate                 DateTime? @map("start_date")
  endDate                   DateTime? @map("end_date")
  activeMilestones          Json?     @map("active_milestones")
  superintendentAssignments Json?     @map("superintendent_assignments")
  contractValue             Decimal?  @map("contract_value") @db.Decimal(15, 2)
  trirTarget                Float?    @default(1.0) @map("trir_target")
  latitude                  Float?    @map("latitude")
  longitude                 Float?    @map("longitude")
  city                      String?   @map("city")
  state                     String?   @map("state")
  createdAt                 DateTime  @default(now()) @map("created_at")
  updatedAt                 DateTime  @updatedAt @map("updated_at")

  workBreakdownItems     WorkBreakdownItem[]
  scheduleActivities     ScheduleActivity[]
  activityRelationships  ActivityRelationship[]
  scheduleBaselines      ScheduleBaseline[]
  scheduleChangeRequests ScheduleChangeRequest[]
  budgetLines            BudgetLine[]
  costTransactions       CostTransaction[]
  purchaseOrders         PurchaseOrder[]
  materialDeliveries     MaterialDelivery[]
  invoices               Invoice[]
  subcontracts           Subcontract[]
  scopeStatements        ScopeStatement[]
  changeOrders           ChangeOrder[]
  rfis                   Rfi[]
  submittals             Submittal[]
  riskItems              RiskItem[]
  issues                 Issue[]
  voiceMemos             VoiceMemo[]
  unifiedChangeLogs      UnifiedChangeLog[]
  closeoutChecklists     CloseoutChecklist[]
  equipment              Equipment[]
  attendances            Attendance[]
  meetings               Meeting[]
  ownerReports           OwnerReport[]
  lessonsLearned         LessonLearned[]
  documents              Document[]

  @@map("projects")
}

// Drawing / document repository. Each Document is a logical file
// (e.g. "A-101 — First Floor Plan"); DocumentRevision is one version
// of it. R2 is the blob store; the metadata lives here.
model Document {
  id                String    @id @default(cuid())
  projectId         String    @map("project_id")
  project           Project   @relation(fields: [projectId], references: [id])
  name              String
  discipline        String // "architectural" | "structural" | "mechanical" | ...
  drawingNo         String?   @map("drawing_no")
  // "current" | "superseded" | "void"
  status            String    @default("current")
  // Sprint 9: tracks the latest revision that was released as IFC.
  currentRevisionId String?   @map("current_revision_id")
  ifcReleasedAt     DateTime? @map("ifc_released_at")
  ifcReleasedBy     String?   @map("ifc_released_by")
  createdBy         String    @map("created_by")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  revisions DocumentRevision[]

  @@index([projectId])
  @@index([projectId, status])
  @@map("documents")
}

model DocumentRevision {
  id           String   @id @default(cuid())
  documentId   String   @map("document_id")
  document     Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  revisionNo   Int      @map("revision_no")
  // The R2 object key, e.g. "projects/p1/docs/<docId>/<revNo>-<sha>.pdf"
  storageKey   String   @map("storage_key")
  contentType  String   @map("content_type")
  sizeBytes    Int      @map("size_bytes")
  // sha256 hex digest, populated on confirm
  sha256       String?  @map("sha256")
  uploadedBy   String   @map("uploaded_by")
  uploadedAt   DateTime @default(now()) @map("uploaded_at")
  notes        String?
  // "pending" | "uploaded" | "failed" — set by the confirm endpoint
  uploadStatus String   @default("pending") @map("upload_status")

  @@unique([documentId, revisionNo])
  @@index([documentId])
  @@map("document_revisions")
}

// Audit log for document downloads. Created on every presigned-GET
// issuance (so we know who requested access, not just who got the
// URL — useful when the URL is shared and we need to roll a key).
model DocumentDownloadLog {
  id           String   @id @default(cuid())
  documentId   String   @map("document_id")
  revisionId   String?  @map("revision_id")
  userId       String   @map("user_id")
  downloadedAt DateTime @default(now()) @map("downloaded_at")
  ipAddress    String?  @map("ip_address")

  @@index([documentId])
  @@index([userId])
  @@map("document_download_logs")
}

model WorkBreakdownItem {
  id            String   @id @default(cuid())
  projectId     String   @map("project_id")
  project       Project  @relation(fields: [projectId], references: [id])
  structureType String   @map("structure_type")
  code          String
  name          String
  parentId      String?  @map("parent_id")
  level         Int      @default(1)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("work_breakdown_items")
}

model WbsCostCodeCrosswalk {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  gcItemId  String   @map("gc_item_id")
  subItemId String   @map("sub_item_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("wbs_cost_code_crosswalk")
}

model ScheduleActivity {
  id              String    @id @default(cuid())
  projectId       String    @map("project_id")
  project         Project   @relation(fields: [projectId], references: [id])
  name            String
  description     String?
  wbsItemId       String?   @map("wbs_item_id")
  startDate       DateTime  @map("start_date")
  endDate         DateTime  @map("end_date")
  duration        Int // in working days
  percentComplete Float     @default(0) @map("percent_complete")
  status          String    @default("not_started") // not_started, in_progress, complete, delayed
  isMilestone     Boolean   @default(false) @map("is_milestone")
  isCritical      Boolean   @default(false) @map("is_critical")
  totalFloat      Float?    @map("total_float") // in days
  freeFloat       Float?    @map("free_float") // in days
  earlyStart      DateTime? @map("early_start")
  earlyFinish     DateTime? @map("early_finish")
  lateStart       DateTime? @map("late_start")
  lateFinish      DateTime? @map("late_finish")
  predecessors    Json? // array of {activityId, type (FS|SS|FF|SF), lag (days)}
  successors      Json? // array of {activityId, type, lag}
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  predecessorsRel ActivityRelationship[] @relation("ActivityPredecessors")
  successorsRel   ActivityRelationship[] @relation("ActivitySuccessors")

  @@map("schedule_activities")
}

model ActivityRelationship {
  id               String           @id @default(cuid())
  projectId        String           @map("project_id")
  project          Project          @relation(fields: [projectId], references: [id])
  predecessorId    String           @map("predecessor_id")
  predecessor      ScheduleActivity @relation("ActivitySuccessors", fields: [predecessorId], references: [id], onDelete: Cascade)
  successorId      String           @map("successor_id")
  successor        ScheduleActivity @relation("ActivityPredecessors", fields: [successorId], references: [id], onDelete: Cascade)
  relationshipType String           @map("relationship_type") // FS, SS, FF, SF
  lagDays          Int              @default(0) @map("lag_days")
  constraintType   String           @default("hard") @map("constraint_type") // hard, soft
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  @@unique([predecessorId, successorId, relationshipType])
  @@map("activity_relationships")
}

model ScheduleBaseline {
  id           String   @id @default(cuid())
  projectId    String   @map("project_id")
  project      Project  @relation(fields: [projectId], references: [id])
  name         String
  locked       Boolean  @default(false)
  baselineDate DateTime @map("baseline_date")
  activities   Json // snapshot of all activities at baseline time (array of activity objects)
  createdBy    String   @map("created_by")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("schedule_baselines")
}

model ScheduleChangeRequest {
  id                 String    @id @default(cuid())
  projectId          String    @map("project_id")
  project            Project   @relation(fields: [projectId], references: [id])
  activityId         String    @map("activity_id")
  requestedBy        String    @map("requested_by")
  reasonCode         String    @map("reason_code")
  proposedStart      DateTime? @map("proposed_start")
  proposedEnd        DateTime? @map("proposed_end")
  impactDescription  String?   @map("impact_description")
  criticalPathImpact Float?    @map("critical_path_impact") // in days
  status             String    @default("pending") // pending, approved, modified, rejected
  decisionNotes      String?   @map("decision_notes")
  decidedBy          String?   @map("decided_by")
  decidedAt          DateTime? @map("decided_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@map("schedule_change_requests")
}

model WebhooksLog {
  id         String   @id @default(cuid())
  event      String
  direction  String // inbound | outbound
  payload    Json
  status     String   @default("pending")
  retryCount Int      @default(0) @map("retry_count")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("webhooks_log")
}

model BudgetLine {
  id                String   @id @default(cuid())
  projectId         String   @map("project_id")
  project           Project  @relation(fields: [projectId], references: [id])
  wbsItemId         String?  @map("wbs_item_id")
  costCode          String?  @map("cost_code")
  name              String
  budgetAmount      Decimal  @map("budget_amount") @db.Decimal(15, 2)
  committedAmount   Decimal  @default(0) @map("committed_amount") @db.Decimal(15, 2)
  incurredAmount    Decimal  @default(0) @map("incurred_amount") @db.Decimal(15, 2)
  forecastAmount    Decimal? @map("forecast_amount") @db.Decimal(15, 2)
  percentComplete   Float    @default(0) @map("percent_complete")
  varianceThreshold Float?   @map("variance_threshold")
  varianceFlag      String?  @map("variance_flag")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  costTransactions CostTransaction[]

  @@map("budget_lines")
}

model CostTransaction {
  id              String     @id @default(cuid())
  projectId       String     @map("project_id")
  project         Project    @relation(fields: [projectId], references: [id])
  budgetLineId    String     @map("budget_line_id")
  budgetLine      BudgetLine @relation(fields: [budgetLineId], references: [id])
  type            String
  source          String
  amount          Decimal    @db.Decimal(15, 2)
  description     String?
  transactionDate DateTime   @map("transaction_date")
  referenceId     String?    @map("reference_id")
  createdAt       DateTime   @default(now()) @map("created_at")

  @@map("cost_transactions")
}

model PurchaseOrder {
  id          String   @id @default(cuid())
  projectId   String   @map("project_id")
  project     Project  @relation(fields: [projectId], references: [id])
  poNumber    String   @map("po_number")
  vendorName  String   @map("vendor_name")
  status      String   @default("draft")
  totalAmount Decimal  @map("total_amount") @db.Decimal(15, 2)
  wbsItemId   String?  @map("wbs_item_id")
  activityId  String?  @map("activity_id")
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  lineItems  PurchaseOrderLineItem[]
  deliveries MaterialDelivery[]
  invoices   Invoice[]

  @@map("purchase_orders")
}

model PurchaseOrderLineItem {
  id               String        @id @default(cuid())
  poId             String        @map("po_id")
  purchaseOrder    PurchaseOrder @relation(fields: [poId], references: [id])
  materialName     String        @map("material_name")
  quantity         Decimal       @db.Decimal(12, 4)
  unit             String
  unitPrice        Decimal       @map("unit_price") @db.Decimal(15, 4)
  lineTotal        Decimal       @map("line_total") @db.Decimal(15, 2)
  quantityReceived Decimal       @default(0) @map("quantity_received") @db.Decimal(12, 4)
  createdAt        DateTime      @default(now()) @map("created_at")

  deliveries MaterialDelivery[]

  @@map("po_line_items")
}

model MaterialDelivery {
  id                String                @id @default(cuid())
  projectId         String                @map("project_id")
  project           Project               @relation(fields: [projectId], references: [id])
  poId              String                @map("po_id")
  purchaseOrder     PurchaseOrder         @relation(fields: [poId], references: [id])
  lineItemId        String                @map("line_item_id")
  lineItem          PurchaseOrderLineItem @relation(fields: [lineItemId], references: [id])
  quantityReceived  Decimal               @map("quantity_received") @db.Decimal(12, 4)
  receivedBy        String                @map("received_by")
  receivedAt        DateTime              @map("received_at")
  discrepancies     String?
  deliveryReference String?               @map("delivery_reference")
  createdAt         DateTime              @default(now()) @map("created_at")

  @@map("material_deliveries")
}

model Invoice {
  id            String        @id @default(cuid())
  projectId     String        @map("project_id")
  project       Project       @relation(fields: [projectId], references: [id])
  poId          String        @map("po_id")
  purchaseOrder PurchaseOrder @relation(fields: [poId], references: [id])
  invoiceNumber String        @map("invoice_number")
  invoiceAmount Decimal       @map("invoice_amount") @db.Decimal(15, 2)
  status        String        @default("pending")
  matchStatus   String?       @map("match_status")
  matchNotes    String?       @map("match_notes")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  @@map("invoices")
}

model Subcontract {
  id                String   @id @default(cuid())
  projectId         String   @map("project_id")
  project           Project  @relation(fields: [projectId], references: [id])
  subcontractorName String   @map("subcontractor_name")
  contractAmount    Decimal  @map("contract_amount") @db.Decimal(15, 2)
  scheduleOfValues  Json?    @map("schedule_of_values")
  retentionPercent  Float    @default(0.1) @map("retention_percent")
  status            String   @default("active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  milestones SubcontractMilestone[]

  @@map("subcontracts")
}

model ScopeStatement {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  project   Project  @relation(fields: [projectId], references: [id])
  content   String
  version   Int      @default(1)
  createdBy String   @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("scope_statements")
}

model ChangeOrder {
  id                  String    @id @default(cuid())
  projectId           String    @map("project_id")
  project             Project   @relation(fields: [projectId], references: [id])
  coNumber            String    @map("co_number")
  date                DateTime
  description         String
  status              String    @default("pending")
  dollarValue         Decimal?  @map("dollar_value") @db.Decimal(15, 2)
  scheduleImpact      Float?    @map("schedule_impact")
  approver            String?
  approvedAt          DateTime? @map("approved_at")
  affectedActivityIds Json?     @map("affected_activity_ids")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  @@map("change_orders")
}

model Rfi {
  id               String    @id @default(cuid())
  projectId        String    @map("project_id")
  project          Project   @relation(fields: [projectId], references: [id])
  rfiNumber        String    @map("rfi_number")
  subject          String
  description      String
  status           String    @default("draft")
  submittedBy      String    @map("submitted_by")
  submittedAt      DateTime? @map("submitted_at")
  assignedTo       String?   @map("assigned_to")
  responseText     String?   @map("response_text")
  answeredAt       DateTime? @map("answered_at")
  requiredDate     DateTime? @map("required_date")
  holdOnActivityId String?   @map("hold_on_activity_id")
  sourceReference  String?   @map("source_reference")
  ballInCourt      String?   @map("ball_in_court")
  statusHistory    Json?     @map("status_history")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@map("rfis")
}

model Submittal {
  id               String    @id @default(cuid())
  projectId        String    @map("project_id")
  project          Project   @relation(fields: [projectId], references: [id])
  submittalNumber  String    @map("submittal_number")
  title            String
  description      String?
  status           String    @default("pending")
  specSection      String?   @map("spec_section")
  requiredDate     DateTime? @map("required_date")
  submittedBy      String    @map("submitted_by")
  submittedAt      DateTime? @map("submitted_at")
  reviewedBy       String?   @map("reviewed_by")
  reviewedAt       DateTime? @map("reviewed_at")
  reviewComments   String?   @map("review_comments")
  statusHistory    Json?     @map("status_history")
  holdOnActivityId String?   @map("hold_on_activity_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@map("submittals")
}

model RiskItem {
  id                 String   @id @default(cuid())
  projectId          String   @map("project_id")
  project            Project  @relation(fields: [projectId], references: [id])
  description        String
  category           String
  probability        String
  impact             String
  score              Int
  mitigationPlan     String?  @map("mitigation_plan")
  owner              String
  status             String   @default("open")
  linkedActivityId   String?  @map("linked_activity_id")
  linkedBudgetLineId String?  @map("linked_budget_line_id")
  source             String   @default("manual")
  incidentReference  String?  @map("incident_reference")
  recordable         Boolean  @default(false)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("risk_items")
}

model Issue {
  id          String    @id @default(cuid())
  projectId   String    @map("project_id")
  project     Project   @relation(fields: [projectId], references: [id])
  issueNumber String    @map("issue_number")
  type        String
  source      String
  title       String
  description String
  status      String    @default("open")
  priority    String    @default("medium")
  activityId  String?   @map("activity_id")
  assignee    String?
  dueDate     DateTime? @map("due_date")
  resolvedAt  DateTime? @map("resolved_at")
  notes       Json?     @map("notes")
  createdBy   String    @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("issues")
}

model VoiceMemo {
  id             String   @id @default(cuid())
  projectId      String   @map("project_id")
  project        Project  @relation(fields: [projectId], references: [id])
  audioUrl       String   @map("audio_url")
  transcription  String
  structuredData Json?    @map("structured_data")
  status         String   @default("pending")
  createdBy      String   @map("created_by")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("voice_memos")
}

model UnifiedChangeLog {
  id                 String   @id @default(cuid())
  projectId          String   @map("project_id")
  project            Project  @relation(fields: [projectId], references: [id])
  module             String
  changeType         String   @map("change_type")
  description        String
  affectedRecordId   String?  @map("affected_record_id")
  affectedRecordType String?  @map("affected_record_type")
  changedBy          String   @map("changed_by")
  changedAt          DateTime @map("changed_at")
  createdAt          DateTime @default(now()) @map("created_at")

  @@map("unified_change_log")
}

model ApiUsageLog {
  id           String   @id @default(cuid())
  projectId    String   @map("project_id")
  userId       String   @map("user_id")
  endpoint     String
  model        String
  inputTokens  Int      @default(0) @map("input_tokens")
  outputTokens Int      @default(0) @map("output_tokens")
  costUsd      Float    @default(0) @map("cost_usd")
  success      Boolean  @default(true)
  failureCode  String?  @map("failure_code")
  calledAt     DateTime @map("called_at")

  @@index([projectId, calledAt])
  @@index([userId, calledAt])
  @@map("api_usage_log")
}

model CloseoutChecklist {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  project   Project  @relation(fields: [projectId], references: [id])
  items     Json
  status    String   @default("in_progress")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("closeout_checklists")
}

model Equipment {
  id                String    @id @default(cuid())
  projectId         String    @map("project_id")
  project           Project   @relation(fields: [projectId], references: [id])
  externalId        String    @map("external_id")
  name              String
  type              String?
  status            String    @default("active")
  currentActivityId String?   @map("current_activity_id")
  lastUsageDate     DateTime? @map("last_usage_date")
  totalHours        Float     @default(0) @map("total_hours")
  dailyRate         Decimal?  @map("daily_rate") @db.Decimal(15, 2)
  isOwned           Boolean   @default(false) @map("is_owned")
  serialNumber      String?   @map("serial_number")
  vendor            String?
  calDueDate        DateTime? @map("cal_due_date") @db.Date
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  statusLogs EquipmentStatusLog[]

  @@unique([projectId, externalId])
  @@map("equipment")
}

model EquipmentStatusLog {
  id          String    @id @default(cuid())
  equipmentId String    @map("equipment_id")
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  date        DateTime  @db.Date
  status      String
  hours       Float     @default(0)
  notes       String?
  loggedBy    String?   @map("logged_by")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([equipmentId, date])
  @@map("equipment_status_log")
}

model Attendance {
  id                 String   @id @default(cuid())
  projectId          String   @map("project_id")
  project            Project  @relation(fields: [projectId], references: [id])
  date               DateTime @db.Date
  workerCount        Int      @default(0) @map("worker_count")
  hours              Float    @default(0)
  presentCount       Int?     @map("present_count")
  absentCount        Int?     @map("absent_count")
  lateCount          Int?     @map("late_count")
  notes              String?
  affectedActivities String[] @default([]) @map("affected_activities")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@unique([projectId, date])
  @@map("attendance")
}

model BillingAccount {
  id                   String   @id @default(cuid())
  orgId                String   @unique @map("org_id")
  stripeCustomerId     String   @map("stripe_customer_id")
  stripeSubscriptionId String?  @map("stripe_subscription_id")
  planTier             String   @default("starter") @map("plan_tier")
  status               String   @default("trialing") @map("status")
  currentPeriodEnd     DateTime @map("current_period_end")
  projectLimit         Int      @default(3) @map("project_limit")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@map("billing_accounts")
}

// Per-org API key overrides for enterprise BYOK. The Anthropic client
// checks this table for an org-provided key before falling back to the
// platform key. The keyEncrypted column stores the key as-supplied; a
// future iteration will wrap this with a KMS-backed envelope.
model OrgApiKey {
  id           String   @id @default(cuid())
  orgId        String   @map("org_id")
  provider     String // "anthropic"
  keyEncrypted String   @map("key_encrypted")
  createdBy    String   @map("created_by")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([orgId, provider])
  @@map("org_api_keys")
}

model Meeting {
  id          String   @id @default(cuid())
  projectId   String   @map("project_id")
  project     Project  @relation(fields: [projectId], references: [id])
  title       String
  meetingDate DateTime @map("meeting_date")
  location    String?
  facilitator String?
  attendees   Json? // array of {name, role}
  agenda      Json? // array of strings
  minutes     String?  @db.Text
  actionItems Json?    @map("action_items") // array of {description, assignee, dueDate, status}
  status      String   @default("draft") // draft, published
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("meetings")
}

model ProjectTemplate {
  id                 String   @id @default(cuid())
  orgId              String   @map("org_id")
  name               String
  description        String?
  // Structure type the template applies to (wbs or cost_code).
  structureType      String   @map("structure_type")
  // Snapshot of WBS / cost-code items. Each item is { code, name, parentCode,
  // level, responsibleParty?, budget? } so the template can be re-applied
  // without referencing the source project's item ids.
  snapshot           Json
  // Sprint 7: full project template snapshots. Optional — older templates
  // saved before this field existed will have nulls and behave as
  // WBS-only templates.
  activitiesSnapshot Json?    @map("activities_snapshot")
  budgetSnapshot     Json?    @map("budget_snapshot")
  risksSnapshot      Json?    @map("risks_snapshot")
  lessonsSnapshot    Json?    @map("lessons_snapshot")
  // The project the template was created from, if any. Useful for "see the
  // source" links; not required for the template to function.
  sourceProjectId    String?  @map("source_project_id")
  createdBy          String   @map("created_by")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@index([orgId])
  @@map("project_templates")
}

// Persisted weekly owner reports. The agent generates the report text +
// structured sections, the PM can edit and mark as sent. The dashboard
// surfaces "Owner Report Due" when the current week's report is missing.
model OwnerReport {
  id          String    @id @default(cuid())
  projectId   String    @map("project_id")
  project     Project   @relation(fields: [projectId], references: [id])
  // Friday of the report week. Stored as a date (UTC midnight).
  weekEnding  DateTime  @map("week_ending")
  // Full report payload: { sections, full_report_text, source, ... }.
  reportJson  Json      @map("report_json")
  // Generated by which user (PM/owner_admin uid).
  generatedBy String    @map("generated_by")
  generatedAt DateTime  @default(now()) @map("generated_at")
  // Sent to the owner at — null until the PM clicks "Mark as Sent".
  sentAt      DateTime? @map("sent_at")
  // Free-form note added when sending, optional.
  sentToEmail String?   @map("sent_to_email")

  @@unique([projectId, weekEnding])
  @@index([projectId, weekEnding])
  @@map("owner_reports")
}

// Real-time lessons-learned capture. Lessons can be agent-flagged (auto
// from pattern detection during morning-brief or pattern sweeps), PM-
// entered manually, or field-reported (later, when the field UI ships).
// `addedToTemplate` is set when a lesson should be carried into a project
// template the next time one is saved.
model LessonLearned {
  id              String   @id @default(cuid())
  projectId       String   @map("project_id")
  project         Project  @relation(fields: [projectId], references: [id])
  title           String
  description     String?  @db.Text
  // Category enum (string column for SQLite-friendly migration safety):
  //   schedule, cost, procurement, quality, safety, communications, risk, other
  category        String
  // Source enum:
  //   agent_flagged, pm_entered, field_reported
  source          String
  impact          String?  @db.Text
  recommendation  String?  @db.Text
  // Optional reference to a schedule activity (DFOW) or cost code.
  dfowRef         String?  @map("dfow_ref")
  createdBy       String   @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  // Marks the lesson for inclusion in the next saved project template.
  addedToTemplate Boolean  @default(false) @map("added_to_template")

  @@index([projectId, category])
  @@index([projectId, source])
  @@index([projectId, addedToTemplate])
  @@map("lessons_learned")
}

