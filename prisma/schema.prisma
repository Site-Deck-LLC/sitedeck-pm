// Per-user notification inbox. Sprint 8 Task 6.
// One row per delivery — a notification is generated by a service
// (e.g. an RFI is assigned to user X) and read by the recipient via
// `GET /api/v1/notifications`. The bell-icon badge in the nav
// shows the count of `read = false` rows for the calling user.
//
// `kind` is a string union (not a Postgres enum) so adding a new
// notification type doesn't require a schema change:
//   - rfi_assigned           : RFI ballInCourt set to me
//   - rfi_answered           : someone answered an RFI I authored
//   - issue_assigned         : Issue assignee set to me
//   - schedule_change_request: a SCR now requires my approval
//   - co_approved            : my CO was approved
//   - co_rejected            : my CO was rejected
//   - system                 : catch-all (e.g. project template applied)
// `payload` is a JSON blob for kind-specific extras (projectId, RFI
// number, etc.) so the bell can deep-link to the right screen
// without a second API call.
model Notification {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  kind      String
  title     String
  body      String?
  payload   Json?
  read      Boolean   @default(false)
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId, read, createdAt])
  @@index([userId, createdAt])
  @@map("notifications")
}

// ============================================================================
// SiteDeck Ops — Sprint 10
// ============================================================================
// Internal-only operations console for Site Deck LLC owner_admin users.
// The models below power the /admin section of the PM frontend (and the
// help button on every page). They are NOT exposed to customers.
//
// Architectural note (ADMIN SECURITY RULE): every /admin/* route is gated
// by `requireAuth + requireSiteDeckAdmin` (see src/middleware/express-auth.ts).
// Non-admins get a 404 — never a 403 — so the route does not exist to them.

// BugReport — one row per user-submitted bug from any SiteDeck product
// (PM, Benchmark, Pro, Design). The triage agent in src/ops/triage.agent.ts
// classifies each row and the operator can approve the fix via the
// approval email flow.
model BugReport {
  id                       String    @id @default(cuid())
  // 'pm' | 'benchmark' | 'pro' | 'design'
  product                  String
  userId                   String    @map("user_id")
  projectId                String?   @map("project_id")
  route                    String
  pageTitle                String    @map("page_title")
  // Last 10 console errors captured by the GetHelp button.
  consoleErrors            Json?     @map("console_errors")
  // Most recent API call captured by the request interceptor.
  lastApiCall              Json?     @map("last_api_call")
  // What the user was trying to do. Only the user-action text the user
  // typed is persisted here; the auto-captured fields above are metadata
  // for triage. Free text — sanitized before any AI call.
  userAction               String    @map("user_action")
  browserInfo              Json?     @map("browser_info")
  // 'user_error' | 'feature_request' | 'data_fix' | 'code_change'
  classification           String?
  classificationConfidence Decimal?  @map("classification_confidence") @db.Decimal(5, 2)
  // 'new' | 'triaging' | 'user_error_resolved' | 'feature_logged' |
  // 'data_fixed' | 'code_fix_pending' | 'code_fix_approved' |
  // 'code_fix_deployed' | 'closed'
  status                   String    @default("new")
  blastRadius              Json?     @map("blast_radius")
  suggestedFix             String?   @map("suggested_fix")
  // 'low' | 'medium' | 'high'
  riskLevel                String?   @map("risk_level")
  workaround               String?
  resolvedAt               DateTime? @map("resolved_at")
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")

  approvalToken BugApprovalToken?

  @@index([status, createdAt])
  @@index([product, status])
  @@index([userId])
  @@map("bug_reports")
}

// FeatureRequest — aggregated record of duplicate feature asks. A user
// submitting a FEATURE_REQUEST classification creates a new row; the
// triage agent increments `requestCount` when it detects a duplicate
// (same product, same route, similar description).
model FeatureRequest {
  id           String   @id @default(cuid())
  product      String
  userId       String   @map("user_id")
  projectId    String?  @map("project_id")
  route        String
  description  String
  userRole     String   @map("user_role")
  // 'new' | 'under_review' | 'planned' | 'declined' | 'shipped'
  status       String   @default("new")
  requestCount Int      @default(1) @map("request_count")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([product, status])
  @@index([requestCount])
  @@map("feature_requests")
}

// BugApprovalToken — single-use, time-bound token for the email approval
// flow. Token expires 48h after creation. Tokens are the ONLY way the
// approval flow is exposed — there is no UI-only approval path.
model BugApprovalToken {
  id           String    @id @default(cuid())
  bugReportId  String    @unique @map("bug_report_id")
  bugReport    BugReport @relation(fields: [bugReportId], references: [id], onDelete: Cascade)
  token        String    @unique
  expiresAt    DateTime  @map("expires_at")
  approvedAt   DateTime? @map("approved_at")
  approvedBy   String?   @map("approved_by")
  rejectedAt   DateTime? @map("rejected_at")
  rejectedBy   String?   @map("rejected_by")
  rejectReason String?   @map("reject_reason")

  @@index([token])
  @@index([expiresAt])
  @@map("bug_approval_tokens")
}

// OpsAuditLog — immutable, append-only record of every ops action.
// NEVER updated or deleted (enforced at service layer: only `create` calls).
// Powers the /admin/audit view and the security review of admin actions.
model OpsAuditLog {
  id          String   @id @default(cuid())
  action      String
  performedBy String   @map("performed_by")
  // 'bug_report' | 'feature_request' | 'token' | 'fix_pipeline' | 'system'
  targetType  String   @map("target_type")
  targetId    String   @map("target_id")
  details     Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([action, createdAt])
  @@index([targetType, targetId])
  @@map("ops_audit_log")
}

// CompoundRisk — Sprint 11. Historical record of every compound risk
// the detector has surfaced, so the PM can see how previous cascades
// were resolved and learn from the patterns. The active (open) state
// is the row where resolvedAt is null; a new rule-trigger creates a
// new row rather than updating an existing one. This keeps the
// historical record immutable and lets us see repeat patterns.
model CompoundRisk {
  id            String    @id @default(cuid())
  projectId     String    @map("project_id")
  ruleTriggered String    @map("rule_triggered")
  description   String
  linkedItems   Json?     @map("linked_items")
  detectedAt    DateTime  @default(now()) @map("detected_at")
  resolvedAt    DateTime? @map("resolved_at")
  resolvedBy    String?   @map("resolved_by")
  resolution    String?

  @@index([projectId, detectedAt])
  @@index([resolvedAt])
  @@map("compound_risks")
}
