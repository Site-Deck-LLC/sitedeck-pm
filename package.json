{
  "name": "sitedeck-pm",
  "version": "1.0.0",
  "description": "SiteDeck PM — Project management for EPC contractors",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/server.ts",
