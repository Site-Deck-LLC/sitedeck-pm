# Database — required
# Use a free cloud Postgres (Supabase, Neon, Railway) or local Postgres
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Dev auth bypass — no Firebase needed for local testing
# Send header: Authorization: Bearer dev-token
# Optional: change role (project_manager, owner_admin, superintendent, owners_rep, etc.)
# DEV_USER_ROLE=project_manager

# Production only: Firebase Admin service account
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json
