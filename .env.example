# Database — Self-hosted Postgres (primary)
# Supabase form preserved below as fallback
# reference. Production uses the local
# container on the VPS groundcheck bridge.
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT].supabase.co:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT].supabase.co:5432/postgres"

# Self-hosted Postgres (current production):
# DATABASE_URL="postgresql://sitedeck:[password]@sitedeck-pm-postgres:5432/sitedeck_pm_dev"
# DIRECT_URL="postgresql://sitedeck:[password]@sitedeck-pm-postgres:5432/sitedeck_pm_dev"

# Auth — Firebase (local dev bypass below)
DEV_USER_ROLE=project_manager

# Stripe — shared account with SiteDeck Pro
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PROFESSIONAL=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# Benchmark Integration (Sprint 13)
# Inbound webhooks from Benchmark are verified with this secret.
BENCHMARK_WEBHOOK_SECRET=...
# Outbound webhooks to Benchmark (project creation, activity linking).
PM_BENCHMARK_WEBHOOK_URL=https://benchmark.sitedeck.pro/api/v1/webhooks/pm
# Optional: dedicated URL for activity-link events (falls back to PM_BENCHMARK_WEBHOOK_URL).
PM_BENCHMARK_ACTIVITY_URL=

# Shared Service Token (PM ↔ Pro integration)
PRO_SERVICE_TOKEN=9936BD06-C760-472C-AC36-FCA33F7806FA
PM_SERVICE_TOKEN=9936BD06-C760-472C-AC36-FCA33F7806FA

# Firebase Functions (PM → Pro task assignment)
FIREBASE_FUNCTIONS_URL=https://us-central1-site-deck.cloudfunctions.net
